{
  "name": "@decentralchain/node-api-js",
  "version": "2.0.0",
  "description": "TypeScript/JavaScript HTTP client for the DecentralChain node REST API",
  "type": "module",
  "packageManager": "npm@11.4.2",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Decentral-America/node-api-js.git"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/Decentral-America"
  },
  "homepage": "https://github.com/Decentral-America/node-api-js#readme",
  "bugs": {
    "url": "https://github.com/Decentral-America/node-api-js/issues"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:publint": "publint",
    "check:exports": "attw --pack . --profile esm-only",
    "check:size": "size-limit",
    "validate": "npm audit --audit-level=high && npm run format:check && npm run lint && npm run typecheck && npm run test && npm run build && npm run check:publint && npm run check:exports && npm run check:size",
    "bulletproof": "npm run format && npm run lint:fix && npm run typecheck && npm run test",
    "bulletproof:check": "npm run format:check && npm run lint && npm run typecheck && npm run test",
    "prepare": "husky",
    "prepack": "npm run build",
    "postversion": "npm publish",
    "postpublish": "git push"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.json": [
      "prettier --write"
    ]
  },
  "size-limit": [
    {
      "path": "./dist/index.mjs",
      "limit": "105 kB"
    }
  ],
  "keywords": [
    "decentralchain",
    "dcc",
    "node-api",
    "blockchain",
    "rest-api",
    "sdk",
    "typescript"
  ],
  "author": "DecentralChain",
  "license": "MIT",
  "dependencies": {
    "@decentralchain/bignumber": "npm:@waves/bignumber@^1.2.0",
    "@decentralchain/ts-lib-crypto": "npm:@waves/ts-lib-crypto@^1.4.4",
    "@decentralchain/ts-types": "npm:@waves/ts-types@^1.2.0",
    "typed-ts-events": "^3.0.1"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "0.18.2",
    "@decentralchain/transactions": "npm:@decentralchain/waves-transactions@4.2.6",
    "@eslint/js": "10.0.1",
    "@size-limit/preset-small-lib": "12.0.0",
    "@types/node": "24.11.0",
    "@vitest/coverage-v8": "4.0.18",
    "eslint": "10.0.2",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "lint-staged": "16.3.1",
    "prettier": "3.8.1",
    "publint": "0.3.18",
    "size-limit": "12.0.0",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1",
    "vitest": "4.0.18"
  }
}
